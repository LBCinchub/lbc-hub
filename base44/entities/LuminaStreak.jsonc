    },
    "current_streak": {
      "type": "number",
      "default": 0
    },
    "longest_streak": {
      "type": "number",
      "default": 0
    },
    "total_sparks": {
      "type": "number",
      "default": 0
    },
    "last_active_date": {
      "type": "string",
      "description": "ISO date string YYYY-MM-DD"
    }
  },
  "required": [
